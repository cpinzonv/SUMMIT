# Production build config (Vite reads this during `vite build`).
# Without this, API_URL falls back to http://localhost:4000, so the deployed
# site calls localhost from the user's browser and every save silently fails
# ("data shows in the UI but disappears on refresh"). This points the built
# frontend at the live Railway backend. A dashboard-set VITE_API_URL still wins.
VITE_API_URL=https://student-workflowserver-production.up.railway.app
