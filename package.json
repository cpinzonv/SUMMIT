{
  "name": "student-workflow-app",
  "version": "0.1.0",
  "private": true,
  "description": "Student workflow app for tracking classes, assignments, and grades across a semester.",
  "workspaces": [
    "server",
    "client",
    "desktop"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=server",
    "db:migrate": "npm run db:migrate --workspace=server",
    "db:seed": "npm run db:seed --workspace=server"
  },
  "engines": {
    "node": ">=20"
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "electron@33.4.11": true,
    "fsevents@2.3.3": true
  }
}
