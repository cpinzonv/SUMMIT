# Copy to .env and fill in. Never commit the real .env.

# Server
PORT=4000
NODE_ENV=development

# CORS — comma-separated list of allowed origins.
#   5173            = Vite web dev server
#   3000            = Electron dev renderer
#   app://bundle    = packaged Electron app (custom protocol origin)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,app://bundle

# Database
# Railway provides DATABASE_URL automatically in production.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/student_workflow
# Set to true when connecting to a managed PG that requires SSL (e.g. Railway).
DATABASE_SSL=false

# Auth — generate strong random secrets, e.g. `openssl rand -hex 32`
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Claude API — required for syllabus PDF extraction (POST /api/classes/extract-syllabus).
# Get a key at https://console.anthropic.com/ . The feature returns 503 if unset.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ---- LMS integration (Canvas) -------------------------------------------------
# Encryption key for OAuth tokens stored at rest (AES-256-GCM). REQUIRED to use
# the Canvas feature. Generate with: openssl rand -hex 32
LMS_TOKEN_ENC_KEY=
# Where Canvas redirects after consent — a frontend route that posts the code
# back to /api/auth/canvas/callback.
LMS_REDIRECT_URI=http://localhost:5173/lms/callback
# Canvas OAuth2 developer key (an institution Canvas admin issues a Developer Key
# with the redirect URI above). The feature 503s until both are set.
CANVAS_CLIENT_ID=
CANVAS_CLIENT_SECRET=
# Dev only: use an in-memory fixture LMS so the whole connect/sync/import flow
# works without real Canvas credentials. Leave false/unset in production.
LMS_MOCK=false
