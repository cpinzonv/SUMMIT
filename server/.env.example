# Copy to .env and fill in. Never commit the real .env.

# Server
PORT=4000
NODE_ENV=development

# CORS — comma-separated list of allowed origins.
#   5173            = Vite web dev server
#   3000            = Electron dev renderer
#   app://bundle    = packaged Electron app (custom protocol origin)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,app://bundle

# Public base URL of THIS server (used to build OAuth provider callback URLs).
# In production set to your API's public URL, e.g. https://api.summit.app
SERVER_URL=http://localhost:4000
# Where the web client (SPA) lives. OAuth finishes by redirecting the browser
# here (/auth/callback) with tokens in the URL fragment. Prod e.g. https://summit.vercel.app
CLIENT_URL=http://localhost:5173

# Database
# Railway provides DATABASE_URL automatically in production.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/student_workflow
# Set to true when connecting to a managed PG that requires SSL (e.g. Railway).
DATABASE_SSL=false

# Auth — generate strong random secrets, e.g. `openssl rand -hex 32`
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Claude API — required for syllabus PDF extraction (POST /api/classes/extract-syllabus).
# Get a key at https://console.anthropic.com/ . The feature returns 503 if unset.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Optional: ElevenLabs text-to-speech for Learn-tab podcast audio. Without it,
# podcasts still generate a script/transcript but the audio is marked "pending".
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL=eleven_multilingual_v2

# ---- Admin -------------------------------------------------------------------
# One-time token for the first-admin bootstrap endpoint
# (POST /api/admin/bootstrap?token=...  body: { "email": "you@school.edu" }).
# Leave UNSET in normal operation — the endpoint is disabled without it, and it
# self-disables once any admin exists. The primary way to make an admin is the
# manual SQL update: UPDATE users SET role='admin' WHERE email='you@school.edu';
# Generate with: openssl rand -hex 32
SETUP_TOKEN=

# ---- OAuth social login (Google / Apple / GitHub) ----------------------------
# Each provider is OPTIONAL: its "Continue with …" button + endpoints only
# activate when its credentials are present (GET /api/auth/providers reports
# which are live). The OAuth callback hits THIS server, which then redirects the
# browser to CLIENT_URL/auth/callback with the tokens. Register these exact
# callback (redirect) URIs with each provider — note they point at the API
# (SERVER_URL), not the SPA:
#   Google: ${SERVER_URL}/api/auth/google/callback
#   GitHub: ${SERVER_URL}/api/auth/github/callback
#   Apple:  ${SERVER_URL}/api/auth/apple/callback
# e.g. locally http://localhost:4000/api/auth/google/callback
#
# Google — Google Cloud Console → APIs & Services → Credentials → OAuth client ID (Web).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
#
# GitHub — Settings → Developer settings → OAuth Apps.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
#
# Apple — Apple Developer → Certificates, Identifiers & Profiles.
#   CLIENT_ID = the Services ID (e.g. app.summit.web)
#   TEAM_ID   = your 10-char Apple Team ID
#   KEY_ID    = the key id for the Sign in with Apple .p8 key
#   PRIVATE_KEY = the .p8 contents (paste with literal \n between lines, or the raw PEM)
APPLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_TEAM_ID=
APPLE_OAUTH_KEY_ID=
APPLE_OAUTH_PRIVATE_KEY=

# ---- Encryption ---------------------------------------------------------------
# Symmetric key (64 hex chars) for secrets stored at rest (AES-256-GCM): 2FA
# secrets/backup codes AND LMS OAuth tokens. REQUIRED for 2FA and LMS features.
# Generate with: openssl rand -hex 32
APP_ENCRYPTION_KEY=

# ---- LMS integration (Canvas, Blackboard, Google Classroom, Brightspace, ------
#      Moodle, Sakai) --------------------------------------------------------
# Legacy alias for APP_ENCRYPTION_KEY (used if APP_ENCRYPTION_KEY is unset).
LMS_TOKEN_ENC_KEY=
# Where a provider redirects after consent — a frontend route (/lms/callback)
# that posts the code back to /api/<provider>/connect.
LMS_REDIRECT_URI=http://localhost:5173/lms/callback

# Dev only: run EVERY provider against in-memory fixtures so the whole
# connect/sync/import flow works without real credentials. Leave false in prod.
# You can also mock providers individually with MOCK_<PROVIDER>_MODE=true below.
LMS_MOCK=false

# Per-provider OAuth2 client credentials. Each provider 503s until its pair is
# set (or it is mocked). A provider can be mocked on its own with its MOCK flag.
#
# Canvas — institution Canvas admin issues a Developer Key with the redirect URI.
CANVAS_CLIENT_ID=
CANVAS_CLIENT_SECRET=
MOCK_CANVAS_MODE=false
#
# Blackboard — register a REST application in the Blackboard Developer Portal.
BLACKBOARD_CLIENT_ID=
BLACKBOARD_CLIENT_SECRET=
MOCK_BLACKBOARD_MODE=false
#
# Google Classroom — OAuth client (Web) in Google Cloud Console; enable the
# Classroom API and add the redirect URI above. Single-tenant (no domain).
GOOGLE_CLASSROOM_CLIENT_ID=
GOOGLE_CLASSROOM_CLIENT_SECRET=
MOCK_GOOGLE_CLASSROOM_MODE=false
#
# Brightspace (D2L) — register an OAuth2 app at auth.brightspace.com.
BRIGHTSPACE_CLIENT_ID=
BRIGHTSPACE_CLIENT_SECRET=
MOCK_BRIGHTSPACE_MODE=false
#
# Moodle — OAuth2 client on the Moodle site (or provision a web service token and
# store it as the access token; the REST calls are identical).
MOODLE_CLIENT_ID=
MOODLE_CLIENT_SECRET=
MOCK_MOODLE_MODE=false
#
# Sakai — OAuth provider tool on the Sakai deployment.
SAKAI_CLIENT_ID=
SAKAI_CLIENT_SECRET=
MOCK_SAKAI_MODE=false
